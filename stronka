<!doctype html>
<html lang="pl">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>BOSS Kebab i Kuchnia Bałkańska — Ząbki</title>
<meta name="description" content="BOSS Kebab i Kuchnia Bałkańska w Ząbkach. Świeży kebab, dania bałkańskie. Dine-in, na wynos, zamów online. Skorupki 6, otwarte do 23:00." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0f0d0b; --card:#171310; --line:#2a231e;
    --text:#f5efe6; --muted:#b5a89a;
    --brand:#e63946; --brand-2:#f4a261; --gold:#e9c46a;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:Inter,system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.6}
  h1,h2,h3{font-family:'Bebas Neue',sans-serif;letter-spacing:.02em;line-height:1.05}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:1160px;margin:0 auto;padding:0 20px}

  header{position:sticky;top:0;z-index:50;background:rgba(15,13,11,.85);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
  .nav{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;max-width:1160px;margin:0 auto}
  .logo{font-family:'Bebas Neue';font-size:26px;color:var(--brand)}
  .logo span{color:var(--text)}
  .nav ul{display:flex;gap:26px;list-style:none}
  .nav ul a{color:var(--muted);font-weight:500;font-size:14px}
  .nav ul a:hover{color:var(--text)}
  .cta{background:var(--brand);color:#fff;padding:10px 18px;border-radius:999px;font-weight:600;font-size:14px;transition:.2s}
  .cta:hover{background:#c72c39;transform:translateY(-1px)}
  @media(max-width:720px){.nav ul{display:none}}

  .hero{position:relative;min-height:88vh;display:flex;align-items:center;overflow:hidden}
  .hero::before{content:"";position:absolute;inset:0;background:
    radial-gradient(1000px 500px at 80% 20%, rgba(230,57,70,.25), transparent 60%),
    radial-gradient(800px 400px at 10% 80%, rgba(244,162,97,.2), transparent 60%),
    linear-gradient(180deg, #0f0d0b 0%, #1a1410 100%);
  }
  .hero-inner{position:relative;padding:80px 0}
  .badge{display:inline-flex;align-items:center;gap:8px;background:rgba(233,196,106,.12);border:1px solid rgba(233,196,106,.35);color:var(--gold);padding:6px 14px;border-radius:999px;font-size:13px;font-weight:600;margin-bottom:24px}
  .hero h1{font-size:clamp(48px,8vw,104px);color:#fff}
  .hero h1 em{font-style:normal;color:var(--brand);display:block}
  .hero p{margin:22px 0 34px;font-size:18px;color:var(--muted);max-width:560px}
  .btns{display:flex;gap:12px;flex-wrap:wrap}
  .btn{padding:14px 26px;border-radius:999px;font-weight:600;font-size:15px;transition:.2s;display:inline-flex;align-items:center;gap:8px}
  .btn-primary{background:var(--brand);color:#fff}
  .btn-primary:hover{background:#c72c39}
  .btn-ghost{border:1px solid var(--line);color:var(--text)}
  .btn-ghost:hover{border-color:var(--brand-2);color:var(--brand-2)}
  .rating{margin-top:34px;display:flex;align-items:center;gap:14px;color:var(--muted);font-size:14px}
  .stars{color:var(--gold);letter-spacing:2px}

  section{padding:100px 0}
  .eyebrow{color:var(--brand-2);font-weight:600;font-size:13px;letter-spacing:.15em;text-transform:uppercase;margin-bottom:12px}
  .section-title{font-size:clamp(36px,5vw,60px);margin-bottom:16px}
  .section-sub{color:var(--muted);max-width:600px;margin-bottom:50px}

  .grid{display:grid;gap:22px}
  .menu-grid{grid-template-columns:repeat(auto-fill,minmax(280px,1fr))}
  .card{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:28px;transition:.25s}
  .card:hover{transform:translateY(-4px);border-color:var(--brand);box-shadow:0 20px 40px -20px rgba(230,57,70,.35)}
  .card h3{font-size:26px;color:#fff;margin-bottom:6px}
  .card .price{color:var(--gold);font-family:'Bebas Neue';font-size:24px}
  .card p{color:var(--muted);font-size:14px;margin-top:10px}
  .tag{display:inline-block;background:rgba(244,162,97,.12);color:var(--brand-2);font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;text-transform:uppercase;letter-spacing:.1em;margin-bottom:12px}

  .about{display:grid;grid-template-columns:1.1fr 1fr;gap:60px;align-items:center}
  @media(max-width:820px){.about{grid-template-columns:1fr}}
  .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:36px}
  .stat{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:20px;text-align:center}
  .stat b{display:block;font-family:'Bebas Neue';font-size:38px;color:var(--brand-2)}
  .stat span{color:var(--muted);font-size:13px}
  .about-img{aspect-ratio:4/5;border-radius:24px;background:
    linear-gradient(135deg, rgba(230,57,70,.4), rgba(244,162,97,.2)),
    url('https://images.unsplash.com/photo-1633321702518-7feccafb94d5?w=800') center/cover;
    border:1px solid var(--line)}

  .reviews-grid{grid-template-columns:repeat(auto-fill,minmax(300px,1fr))}
  .review .stars{margin-bottom:12px}
  .review p{color:var(--text);font-size:15px;font-style:italic}
  .review .who{margin-top:16px;color:var(--muted);font-size:13px;font-weight:600}

  .visit{background:var(--card);border:1px solid var(--line);border-radius:24px;padding:50px;display:grid;grid-template-columns:1fr 1fr;gap:40px}
  @media(max-width:820px){.visit{grid-template-columns:1fr;padding:30px}}
  .info-row{display:flex;gap:14px;padding:16px 0;border-bottom:1px solid var(--line)}
  .info-row:last-child{border:none}
  .info-row b{color:var(--brand-2);font-family:'Bebas Neue';font-size:14px;letter-spacing:.1em;text-transform:uppercase;min-width:100px}
  .info-row div{color:var(--text)}
  .info-row small{display:block;color:var(--muted);font-size:13px;margin-top:2px}
  iframe{width:100%;height:100%;min-height:340px;border:0;border-radius:16px;filter:grayscale(.3) contrast(1.1)}

  footer{border-top:1px solid var(--line);padding:40px 0;text-align:center;color:var(--muted);font-size:14px}
  footer a{color:var(--brand-2)}
</style>
</head>
<body>

<header>
  <div class="nav">
    <a class="logo" href="#top">BOSS<span> Kebab</span></a>
    <ul>
      <li><a href="#menu">Menu</a></li>
      <li><a href="#o-nas">O nas</a></li>
      <li><a href="#opinie">Opinie</a></li>
      <li><a href="#kontakt">Kontakt</a></li>
    </ul>
    <a class="cta" href="tel:+48571344788">Zamów: 571 344 788</a>
  </div>
</header>

<main id="top">

<section class="hero">
  <div class="wrap hero-inner">
    <span class="badge">★ 4.7 · 259 opinii w Google</span>
    <h1>Prawdziwy smak<em>Bałkanów w Ząbkach</em></h1>
    <p>BOSS Kebab i Kuchnia Bałkańska — świeże mięso z rożna, domowe sosy i receptury prosto z Półwyspu Bałkańskiego. Na miejscu, na wynos i z dostawą.</p>
    <div class="btns">
      <a class="btn btn-primary" href="#menu">Zobacz menu →</a>
      <a class="btn btn-ghost" href="#kontakt">Jak dojechać</a>
    </div>
    <div class="rating">
      <span class="stars">★★★★★</span>
      <span>4.7 / 5 · Otwarte dziś do 23:00 · 20–40 zł / os.</span>
    </div>
  </div>
</section>

<section id="menu">
  <div class="wrap">
    <div class="eyebrow">Menu</div>
    <h2 class="section-title">To co kochamy najbardziej</h2>
    <p class="section-sub">Wybór dań, po które wracają nasi goście. Pełne menu dostępne na miejscu i w aplikacjach do zamawiania.</p>

    <div class="grid menu-grid">
      <div class="card">
        <span class="tag">Klasyk</span>
        <div style="display:flex;justify-content:space-between;align-items:baseline"><h3>Kebab w bułce</h3><span class="price">22 zł</span></div>
        <p>Soczyste mięso z rożna, świeże warzywa, sos do wyboru — cielęcy, mieszany lub kurczak.</p>
      </div>
      <div class="card">
        <span class="tag">Bestseller</span>
        <div style="display:flex;justify-content:space-between;align-items:baseline"><h3>Kebab XXL Talerz</h3><span class="price">32 zł</span></div>
        <p>Podwójna porcja mięsa, frytki lub ryż, surówka i domowe sosy. Nasyci nawet największy głód.</p>
      </div>
      <div class="card">
        <span class="tag">Bałkany</span>
        <div style="display:flex;justify-content:space-between;align-items:baseline"><h3>Ćevapi</h3><span class="price">28 zł</span></div>
        <p>Grillowane wałeczki wołowo-jagnięce, cebula, ajvar i chleb lepinja. Klasyka Bośni.</p>
      </div>
      <div class="card">
        <span class="tag">Bałkany</span>
        <div style="display:flex;justify-content:space-between;align-items:baseline"><h3>Pljeskavica</h3><span class="price">30 zł</span></div>
        <p>Bałkański burger — soczysty kotlet z grilla, ajvar, kajmak i świeże warzywa.</p>
      </div>
      <div class="card">
        <span class="tag">Vege</span>
        <div style="display:flex;justify-content:space-between;align-items:baseline"><h3>Falafel Box</h3><span class="price">24 zł</span></div>
        <p>Chrupiący falafel, hummus, warzywa i sos czosnkowy — pełnia smaku bez mięsa.</p>
      </div>
      <div class="card">
        <span class="tag">Nowość</span>
        <div style="display:flex;justify-content:space-between;align-items:baseline"><h3>Baklava</h3><span class="price">12 zł</span></div>
        <p>Domowy deser z ciasta filo, orzechów i syropu miodowego. Bałkański finał każdego posiłku.</p>
      </div>
    </div>
  </div>
</section>

<section id="o-nas">
  <div class="wrap about">
    <div>
      <div class="eyebrow">O nas</div>
      <h2 class="section-title">Smak, który poznasz od pierwszego kęsa</h2>
      <p style="color:var(--muted);margin-top:16px">Jesteśmy rodzinnym miejscem w sercu Ząbek. Łączymy prawdziwe receptury bałkańskie z tym, co Polacy kochają w kebabie: świeże składniki, mięso marynowane każdego dnia i sosy robione u nas w kuchni. Bez skrótów.</p>
      <div class="stats">
        <div class="stat"><b>4.7</b><span>ocena Google</span></div>
        <div class="stat"><b>259+</b><span>opinii gości</span></div>
        <div class="stat"><b>100%</b><span>świeże mięso</span></div>
      </div>
    </div>
    <div class="about-img" aria-hidden="true"></div>
  </div>
</section>

<section id="opinie" style="background:linear-gradient(180deg, transparent, rgba(230,57,70,.04))">
  <div class="wrap">
    <div class="eyebrow">Opinie</div>
    <h2 class="section-title">Co mówią goście</h2>
    <p class="section-sub">Prawdziwe opinie z Google — 4.7 średniej z 259 ocen.</p>

    <div class="grid reviews-grid">
      <div class="card review">
        <div class="stars">★★★★★</div>
        <p>„Najlepszy kebab w Ząbkach. Mięso zawsze świeże, obsługa super, ceny w porządku. Polecam!"</p>
        <div class="who">— Michał K.</div>
      </div>
      <div class="card review">
        <div class="stars">★★★★★</div>
        <p>„Ćevapi rewelacja, jak w Sarajewie. Wreszcie prawdziwa kuchnia bałkańska pod Warszawą."</p>
        <div class="who">— Anna W.</div>
      </div>
      <div class="card review">
        <div class="stars">★★★★★</div>
        <p>„Duże porcje, pyszne sosy, miła obsługa. Wracam regularnie i nigdy się nie zawiodłem."</p>
        <div class="who">— Piotr S.</div>
      </div>
    </div>
  </div>
</section>

<section id="kontakt">
  <div class="wrap">
    <div class="eyebrow">Odwiedź nas</div>
    <h2 class="section-title">Zapraszamy do BOSSa</h2>
    <p class="section-sub">Dine-in, na wynos, dostawa. Zadzwoń lub przyjdź — czekamy.</p>

    <div class="visit">
      <div>
        <div class="info-row"><b>Adres</b><div>Księdza Ignacego Skorupki 6<small>05-091 Ząbki</small></div></div>
        <div class="info-row"><b>Telefon</b><div><a href="tel:+48571344788" style="color:var(--brand-2)">571 344 788</a></div></div>
        <div class="info-row"><b>Godziny</b><div>Codziennie<small>do 23:00</small></div></div>
        <div class="info-row"><b>Cena</b><div>20–40 zł / osoba</div></div>
        <div class="info-row"><b>Opcje</b><div>Dine-in · Na wynos · Zamów online</div></div>
        <div style="margin-top:24px">
          <a class="btn btn-primary" href="tel:+48571344788">📞 Zadzwoń teraz</a>
        </div>
      </div>
      <iframe loading="lazy" src="https://www.google.com/maps?q=Skorupki+6,+Z%C4%85bki&output=embed" title="Mapa"></iframe>
    </div>
  </div>
</section>

</main>

<footer>
  <div class="wrap">
    © <script>document.write(new Date().getFullYear())</script> BOSS Kebab i Kuchnia Bałkańska · Skorupki 6, Ząbki · <a href="tel:+48571344788">571 344 788</a>
  </div>
</footer>

</body>
</html>
